<div class="school">
  <button
    class="btn btn-lg focus-ring focus-ring-primary selections-btn"
    style="background-color: #402b3a; color: white; width: 50rem; height: 4rem"
    type="button"
    data-bs-toggle="offcanvas"
    data-bs-target="#schoolOffcanvas"
    id="btnschool"
    aria-controls="offcanvasWithBothOptions"
  >
    ~~~ Select Your School ~~~
  </button>
  <input
    type="text"
    name="selections[school]"
    id="schoolname"
    style="display: none"
  />
  <div
    class="offcanvas offcanvas-end"
    data-bs-theme="dark"
    data-bs-scroll="true"
    tabindex="-1"
    id="schoolOffcanvas"
  >
    <div class="offcanvas-header">
      <h5 class="offcanvas-title" id="offcanvasWithBothOptionsLabel">
        Select Your School Name <br />From Below :
      </h5>
      <button
        type="button"
        class="btn-close"
        id="btn-close-school"
        data-bs-dismiss="offcanvas"
      ></button>
    </div>
    <div class="offcanvas-body">
      <!--  -->
      <ol class="list-group list-group-numbered" id="clickableList">
        <%for(school of schools){%>

        <li class="list-group-item list-group-item-primary">
          <%=school.name%>
        </li>

        <%}%>
      </ol>
      <!--  -->
    </div>
  </div>
</div>

<script>
  let btnschool = document.querySelector("#btnschool");
  let inpforschool = document.querySelector("#schoolname");
  let btncloseschool = document.querySelector("#btn-close-school");

  const listItems = document.querySelectorAll("#clickableList li");
  listItems.forEach((item) => {
    item.addEventListener("click", function () {
      const text = this.textContent.trim();
      btnschool.textContent = text;
      inpforschool.value = text;
      btncloseschool.click();
    });
  });
</script>
