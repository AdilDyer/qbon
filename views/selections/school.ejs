<div class="school">
  <button
    class="btn btn-lg focus-ring focus-ring-primary selections-btn"
    style="background-color: #402b3a; color: white; width: 50rem; height: 4rem"
    type="button"
    data-bs-toggle="offcanvas"
    data-bs-target="#schoolOffcanvas"
    aria-controls="offcanvasWithBothOptions"
  >
    ~~~ Select Your School ~~~
  </button>

  <div
    class="offcanvas offcanvas-end"
    data-bs-theme="dark"
    data-bs-scroll="true"
    tabindex="-1"
    id="schoolOffcanvas"
  >
    <div class="offcanvas-header">
      <h5 class="offcanvas-title" id="offcanvasWithBothOptionsLabel">
        Select Your School Name <br />From Below :
      </h5>
      <button
        type="button"
        class="btn-close"
        data-bs-dismiss="offcanvas"
      ></button>
    </div>
    <div class="offcanvas-body">
      <!--  -->
      <ol class="list-group list-group-numbered">
        <li class="list-group-item list-group-item-primary">
          SCHOOL OF CYBERSECURITY AND DIGITAL FORENSICS
        </li>
        <li class="list-group-item list-group-item-success">
          SCHOOL OF LAW AND SOCIAL JUSTICE
        </li>
        <li class="list-group-item list-group-item-danger">
          SCHOOL OF MANAGEMENT AND BUSINESS STUDIES
        </li>
        <li class="list-group-item list-group-item-warning">
          SCHOOL OF CYBERSECURITY AND DIGITAL FORENSICS
        </li>
        <li class="list-group-item list-group-item-secondary">
          SCHOOL OF LAW AND SOCIAL JUSTICE
        </li>
        <li class="list-group-item list-group-item-info">
          SCHOOL OF MANAGEMENT AND BUSINESS STUDIES
        </li>
        <li class="list-group-item list-group-item-light">
          SCHOOL OF LAW AND SOCIAL JUSTICE
        </li>
        <li class="list-group-item list-group-item-dark">
          SCHOOL OF MANAGEMENT AND BUSINESS STUDIES
        </li>
      </ol>
      <!--  -->
    </div>
  </div>
</div>
