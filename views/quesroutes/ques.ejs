<%layout("/layouts/boilerplate.ejs")%>

<div
  class="body-index"
  style="
    width: 100%;
    height: fit-content;
    display: flex;
    align-items: center;
    justify-content: center;
  "
>
  <button
    class="btn btn-lg focus-ring focus-ring-primary"
    style="
      background-color: #402b3a;
      color: white;
      width: 100%;
      height: 50rem;
      font-weight: bolder;
    "
    type="button"
    data-bs-toggle="offcanvas"
    data-bs-target="#schoolOffcanvas"
    id="btnschool"
    aria-controls="offcanvasWithBothOptions"
  >
    ~~~ Select YEAR ~~~
  </button>
  <div
    class="offcanvas offcanvas-end"
    data-bs-theme="dark"
    data-bs-scroll="true"
    tabindex="-1"
    id="schoolOffcanvas"
  >
    <div class="offcanvas-header">
      <h5 class="offcanvas-title" id="offcanvasWithBothOptionsLabel">
        Select the Year to select <br />From Below :
      </h5>
      <button
        type="button"
        class="btn-close"
        id="btn-close-school"
        data-bs-dismiss="offcanvas"
      ></button>
    </div>
    <div class="offcanvas-body">
      <!--  -->
      <ol class="list-group list-group-numbered" id="years">
        <li class="list-group-item list-group-item-primary">2023-24</li>
        <li class="list-group-item list-group-item-primary">2022-23</li>
        <li class="list-group-item list-group-item-primary">2021-22</li>
        <li class="list-group-item list-group-item-primary">2022-23</li>
      </ol>
      <!--  -->
    </div>
  </div>
</div>

<script>
  let listItems = document.querySelectorAll("#years li");
  let form = document.createElement("form");
  let cont = document.querySelector(".body-index");
  listItems.forEach((li) => {
    li.addEventListener("click", (event) => {
      form.action = "/quesdata";
      let inp = document.createElement("input");
      inp.classList.add("d-none");
      inp.textContent = li.textContent;
      inp.name = "quesyear";
      form.append(inp);
      cont.append(form);
      form.submit();
    });
  });
</script>
