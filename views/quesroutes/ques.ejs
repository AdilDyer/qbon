<%layout("/layouts/boilerplate.ejs")%>
<!-- when stylesheet stops working due to some reason , link it explicitly in that ejs file  -->
<link rel="stylesheet" href="/style.css" />
<div
  class="body-index"
  style="
    width: 100%;
    height: fit-content;
    display: flex;
    align-items: center;
    justify-content: center;
  "
>
  <button
    class="btn btn-lg focus-ring focus-ring-primary"
    style="
      background-color: #402b3a;
      color: white;
      width: 100%;
      height: 50rem;
      font-weight: bolder;
    "
    type="button"
    data-bs-toggle="offcanvas"
    data-bs-target="#schoolOffcanvas"
    id="btnschool"
    aria-controls="offcanvasWithBothOptions"
  >
    ~~~ Select YEAR ~~~
  </button>
  <div
    class="offcanvas offcanvas-end"
    data-bs-theme="dark"
    data-bs-scroll="true"
    tabindex="-1"
    id="schoolOffcanvas"
  >
    <div class="offcanvas-header">
      <h5 class="offcanvas-title" id="offcanvasWithBothOptionsLabel">
        Select the Year to select <br />From Below :
      </h5>
      <button
        type="button"
        class="btn-close"
        id="btn-close-school"
        data-bs-dismiss="offcanvas"
      ></button>
    </div>
    <div class="offcanvas-body">
      <!--  -->
      <ol
        class="list-group list-group-numbered"
        id="years"
        style="cursor: pointer"
      >
        <li class="list-group-item list-group-item-primary">2024</li>
        <li class="list-group-item list-group-item-primary">2023</li>
      </ol>
      <!--  -->
    </div>
  </div>
</div>
<h6 style="display: none" id="subname"><%=subname%></h6>
<script>
  let listItems = document.querySelectorAll("#years li");
  let form = document.createElement("form");
  let h6 = document.getElementById("subname");
  let cont = document.querySelector(".body-index");
  listItems.forEach((li) => {
    li.addEventListener("click", (event) => {
      let subname = h6.innerText.trim();
      form.action = `/quesdata/${subname}`;
      let inp = document.createElement("input");
      inp.classList.add("d-none");
      inp.textContent = li.textContent;
      inp.value = inp.textContent;
      inp.name = "quesyear";
      form.append(inp);
      cont.append(form);
      form.submit();
    });
  });
</script>
